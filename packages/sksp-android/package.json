{
  "name": "@novel-master/sksp-android",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "node --input-type=module --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@novel-master/core": "*",
    "@novel-master/sksp": "*"
  },
  "peerDependencies": {
    "react-native": ">=0.74.0"
  },
  "react-native": {
    "android": {
      "sourceDir": "./android"
    }
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
