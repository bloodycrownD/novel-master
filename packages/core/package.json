{
  "name": "@novel-master/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/public/agent.d.ts",
      "import": "./dist/public/agent.js"
    },
    "./chat": {
      "types": "./dist/public/chat.d.ts",
      "import": "./dist/public/chat.js"
    },
    "./compaction": {
      "types": "./dist/public/compaction.d.ts",
      "import": "./dist/public/compaction.js"
    },
    "./events": {
      "types": "./dist/public/events.d.ts",
      "import": "./dist/public/events.js"
    },
    "./feature-flags": {
      "types": "./dist/public/feature-flags.d.ts",
      "import": "./dist/public/feature-flags.js"
    },
    "./prompt": {
      "types": "./dist/public/prompt.d.ts",
      "import": "./dist/public/prompt.js"
    },
    "./provider": {
      "types": "./dist/public/provider.d.ts",
      "import": "./dist/public/provider.js"
    },
    "./regex": {
      "types": "./dist/public/regex.d.ts",
      "import": "./dist/public/regex.js"
    },
    "./session-fs": {
      "types": "./dist/public/session-fs.d.ts",
      "import": "./dist/public/session-fs.js"
    },
    "./vfs": {
      "types": "./dist/public/vfs.d.ts",
      "import": "./dist/public/vfs.js"
    },
    "./worktree": {
      "types": "./dist/public/worktree.d.ts",
      "import": "./dist/public/worktree.js"
    },
    "./tdbc": {
      "types": "./dist/infra/tdbc/index.d.ts",
      "import": "./dist/infra/tdbc/index.js"
    },
    "./sksp": {
      "types": "./dist/infra/sksp/index.d.ts",
      "import": "./dist/infra/sksp/index.js"
    },
    "./nmtp": {
      "types": "./dist/infra/nmtp/index.d.ts",
      "import": "./dist/infra/nmtp/index.js"
    },
    "./front-matter": {
      "types": "./dist/domain/worktree/logic/front-matter.d.ts",
      "import": "./dist/domain/worktree/logic/front-matter.js"
    },
    "./kkv": {
      "types": "./dist/service/kkv/index.d.ts",
      "import": "./dist/service/kkv/index.js"
    },
    "./config-forms": {
      "types": "./dist/config-forms/index.d.ts",
      "import": "./dist/config-forms/index.js"
    },
    "./config-forms/agent": {
      "types": "./dist/config-forms/agent/index.d.ts",
      "import": "./dist/config-forms/agent/index.js"
    },
    "./config-forms/events": {
      "types": "./dist/config-forms/events/index.d.ts",
      "import": "./dist/config-forms/events/index.js"
    },
    "./config-forms/shared": {
      "types": "./dist/config-forms/shared/index.d.ts",
      "import": "./dist/config-forms/shared/index.js"
    },
    "./config-forms/stored-config-validity": {
      "types": "./dist/config-forms/stored-config-validity/index.d.ts",
      "import": "./dist/config-forms/stored-config-validity/index.js"
    }
  },
  "scripts": {
    "lint": "eslint src test",
    "build": "tsc --build tsconfig.json --force && tsc-alias -p tsconfig.json",
    "rebuild": "npm run clean && npm run build",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "node --input-type=module --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "test": "tsx --experimental-test-module-mocks --tsconfig tsconfig.test.json --test test/**/!(performance).test.ts",
    "test:fast": "tsx --experimental-test-module-mocks --tsconfig tsconfig.test.json --test",
    "test:msg": "npm run test:fast -- test/message-checkpoint/!(performance).test.ts",
    "test:vfs": "npm run test:fast -- test/vfs/*.test.ts",
    "test:perf": "npm run test:fast -- test/message-checkpoint/performance.test.ts"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "iconv-lite": "^0.6.3",
    "yaml": "^2.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@novel-master/tdbc-driver-better-sqlite3": "*",
    "@novel-master/tokenizer-driver-node": "*",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.21.0"
  }
}
