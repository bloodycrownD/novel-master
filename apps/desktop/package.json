{
  "name": "@novel-master/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/main/main.js",
  "scripts": {
    "prebuild": "npm run build -w @novel-master/config-forms",
    "build": "npm run build:icons && vite build && npm run build:main && npm run build:preload",
    "build:icons": "node scripts/generate-icons.mjs",
    "build:main": "tsc -p tsconfig.json",
    "build:preload": "esbuild src/preload/preload.ts --bundle --platform=node --format=cjs --outfile=dist/src/preload/preload.cjs --external:electron",
    "build:renderer": "vite build",
    "dev:vite": "vite",
    "dev:electron": "node scripts/rebuild-native.mjs && npm run build:main && npm run build:preload && electron .",
    "dev": "concurrently -k \"npm run dev:vite\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "dist": "npm run build && node scripts/rebuild-native.mjs && electron-builder",
    "start": "electron .",
    "clean": "node --input-type=module --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "test": "tsx --test test/**/*.test.ts test/**/*.test.js"
  },
  "dependencies": {
    "@novel-master/config-forms": "*",
    "@novel-master/core": "*",
    "@novel-master/sksp-mac": "*",
    "@novel-master/sksp-windows": "*",
    "@novel-master/tdbc-driver-better-sqlite3": "*",
    "@novel-master/tokenizer-driver-node": "*",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "electron": "35.7.5",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "extends": "electron-builder.yml"
  }
}
