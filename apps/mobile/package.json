{
  "name": "@novel-master/mobile",
  "version": "1.3.02",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "log-android": "react-native log-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "start": "react-native start",
    "pretest": "npm run build -w @novel-master/core -w @novel-master/cloud-sync-driver-s3",
    "test": "jest",
    "prebuild": "npm run build -w @novel-master/core",
    "build": "tsc --noEmit -p tsconfig.build.json",
    "e2e": "node ./e2e/scripts/ensure-appium-driver.mjs && wdio run ./e2e/wdio.conf.ts",
    "e2e:fixture": "node ./e2e/scripts/inject-tool-turn-fixture.mjs",
    "e2e:prepare": "node ./e2e/scripts/ensure-appium-driver.mjs",
    "e2e:build-apk": "cd android && gradlew.bat assembleDebug",
    "e2e:tsc": "tsc -p e2e/tsconfig.json",
    "icons": "node scripts/generate-app-icons.mjs",
    "prestart": "npm run build -w @novel-master/core -w @novel-master/cloud-sync-driver-s3 -w @novel-master/sksp-android -w @novel-master/tdbc-driver-rn -w @novel-master/tokenizer-driver-rn",
    "preandroid": "npm run build -w @novel-master/core -w @novel-master/cloud-sync-driver-s3 -w @novel-master/sksp-android -w @novel-master/tdbc-driver-rn -w @novel-master/tokenizer-driver-rn",
    "preios": "npm run build -w @novel-master/core -w @novel-master/cloud-sync-driver-s3 -w @novel-master/sksp-android -w @novel-master/tdbc-driver-rn -w @novel-master/tokenizer-driver-rn"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.1.2",
    "@noble/hashes": "^1.8.0",
    "@novel-master/cloud-sync-driver-s3": "*",
    "@novel-master/core": "*",
    "@novel-master/sksp-android": "*",
    "@novel-master/tdbc-driver-rn": "*",
    "@novel-master/tokenizer-driver-rn": "*",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-documents/picker": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@xmldom/xmldom": "^0.8.13",
    "buffer": "^6.0.3",
    "fast-text-encoding": "^1.0.6",
    "fast-xml-parser": "^5.7.3",
    "js-tiktoken": "^1.0.21",
    "markdown-it": "^14.1.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-blob-util": "^0.22.2",
    "react-native-gesture-handler": "^2.24.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-quick-sqlite": "^8.2.7",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.10.0",
    "react-native-svg": "^15.15.5",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "^13.16.1",
    "readable-stream": "^4.7.0",
    "sanitize-html": "^2.14.0",
    "web-streams-polyfill": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-export-namespace-from": "^7.29.7",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/sanitize-html": "^2.16.1",
    "@wdio/appium-service": "^9.12.0",
    "@wdio/cli": "^9.12.0",
    "@wdio/globals": "^9.12.0",
    "@wdio/local-runner": "^9.12.0",
    "@wdio/mocha-framework": "^9.12.0",
    "@wdio/spec-reporter": "^9.12.0",
    "appium": "^2.18.0",
    "eslint": "^8.19.0",
    "expect-webdriverio": "^5.1.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "sharp": "^0.34.2",
    "typescript": "^5.8.3",
    "webdriverio": "^9.12.0"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
