{
  "name": "novel-master",
  "version": "0.0.0",
  "private": true,
  "description": "Novel Master monorepo",
  "license": "PolyForm-Noncommercial-1.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "test:core:fast": "npm run test:fast -w @novel-master/core",
    "clean": "npm run clean --workspaces --if-present",
    "link:cli": "npm run build -w @novel-master/cli && npm link -w @novel-master/cli",
    "mobile:start": "npm run start -w @novel-master/mobile",
    "mobile:android": "npm run android -w @novel-master/mobile",
    "mobile:log": "npm run log-android -w @novel-master/mobile",
    "mobile:e2e": "npm run e2e -w @novel-master/mobile --",
    "mobile:e2e:fixture": "npm run e2e:fixture -w @novel-master/mobile",
    "mobile:e2e:smoke": "npm run e2e -w @novel-master/mobile -- --spec e2e/specs/smoke.launch.e2e.ts",
    "mobile:e2e:prepare": "npm run e2e:prepare -w @novel-master/mobile",
    "mobile:e2e:build-apk": "npm run e2e:build-apk -w @novel-master/mobile",
    "desktop:dev": "npm run dev -w @novel-master/desktop",
    "desktop:build": "npm run build -w @novel-master/desktop",
    "desktop:dist": "npm run dist -w @novel-master/desktop"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^25.6.2",
    "eslint": "^9.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "engines": {
    "node": ">=20"
  }
}
