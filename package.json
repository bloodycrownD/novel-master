{
  "name": "novel-master",
  "version": "0.0.0",
  "private": true,
  "description": "Novel Master monorepo",
  "license": "PolyForm-Noncommercial-1.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "link:cli": "npm run build -w @novel-master/cli && npm link -w @novel-master/cli",
    "mobile:start": "npm run start -w @novel-master/mobile",
    "mobile:android": "npm run android -w @novel-master/mobile",
    "mobile:log": "npm run log-android -w @novel-master/mobile",
    "desktop:dev": "npm run dev -w @novel-master/desktop",
    "desktop:build": "npm run build -w @novel-master/desktop",
    "desktop:dist": "npm run dist -w @novel-master/desktop"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
